---
---
<!--
  Research constellations.
  Idle state: calm clusters for vision, language, time, space, and embodiment.
-->
<canvas id="bg-canvas" transition:persist="bg-canvas"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -2;
    pointer-events: none;
  }
</style>

<script>
  (function () {
    const canvas = document.getElementById('bg-canvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const initKey = '__stogiannidisResearchConstellationBg';
    if (window[initKey]) return;
    window[initKey] = true;

    const TAU = Math.PI * 2;

    const CLUSTER_DEFS = [
      { id: 'vision', fx: 0.17, fy: 0.24, radius: 72, nodes: 7, drift: 16, markerSize: 13, opacity: 1 },
      { id: 'language', fx: 0.83, fy: 0.29, radius: 80, nodes: 8, drift: 18, markerSize: 14, opacity: 1 },
      { id: 'time', fx: 0.21, fy: 0.77, radius: 78, nodes: 7, drift: 17, markerSize: 13, opacity: 0.98 },
      { id: 'space', fx: 0.81, fy: 0.75, radius: 80, nodes: 8, drift: 18, markerSize: 14, opacity: 1 },
      { id: 'embodiment', fx: 0.54, fy: 0.57, radius: 62, nodes: 6, drift: 12, markerSize: 12, opacity: 0.9 },
    ];

    const BRIDGES = [
      { from: 'vision', to: 'language', bend: -0.08 },
      { from: 'vision', to: 'space', bend: -0.06 },
      { from: 'language', to: 'time', bend: 0.08 },
      { from: 'space', to: 'time', bend: -0.08 },
      { from: 'vision', to: 'embodiment', bend: 0.05 },
      { from: 'language', to: 'embodiment', bend: -0.05 },
    ];

    let width = window.innerWidth;
    let height = window.innerHeight;
    let animationId = 0;
    let clusters = [];

    const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let reduceMotion = reduceMotionQuery.matches;

    function rgba(rgb, alpha) {
      return 'rgba(' + rgb + ', ' + alpha + ')';
    }

    function isDark() {
      return document.documentElement.getAttribute('data-theme') === 'dark';
    }

    function getThemes() {
      if (isDark()) {
        return {
          vision: { main: '77, 168, 218', accent: '232, 180, 80', outline: '56, 120, 170' },
          language: { main: '155, 140, 255', accent: '244, 114, 182', outline: '120, 100, 200' },
          time: { main: '99, 102, 241', accent: '232, 180, 80', outline: '80, 90, 180' },
          space: { main: '62, 207, 190', accent: '155, 140, 255', outline: '50, 160, 150' },
          embodiment: { main: '99, 102, 241', accent: '52, 211, 153', outline: '80, 90, 180' },
        };
      }

      return {
        vision: { main: '52, 152, 219', accent: '202, 138, 4', outline: '41, 128, 185' },
        language: { main: '109, 95, 216', accent: '236, 72, 153', outline: '80, 70, 160' },
        time: { main: '79, 70, 229', accent: '202, 138, 4', outline: '67, 56, 202' },
        space: { main: '24, 160, 148', accent: '109, 95, 216', outline: '20, 130, 120' },
        embodiment: { main: '79, 70, 229', accent: '16, 185, 129', outline: '67, 56, 202' },
      };
    }

    function onReducedMotionChange(event) {
      reduceMotion = event.matches;
      createClusters();
    }

    function createNode(definition, nodeIndex) {
      return {
        angle: (nodeIndex / definition.nodes) * TAU + Math.random() * 0.45,
        radial: definition.radius * (0.42 + Math.random() * 0.56),
        orbitSpeed: (0.22 + Math.random() * 0.2) * (Math.random() < 0.5 ? -1 : 1),
        pulsePhase: Math.random() * TAU,
        pulseSpeed: 0.9 + Math.random() * 1.2,
        size: 1.8 + Math.random() * 2.7,
      };
    }

    function createClusters() {
      clusters = CLUSTER_DEFS.map((definition) => {
        const nodes = [];
        for (let i = 0; i < definition.nodes; i++) {
          nodes.push(createNode(definition, i));
        }

        return {
          ...definition,
          phaseX: Math.random() * TAU,
          phaseY: Math.random() * TAU,
          driftSpeedX: 0.2 + Math.random() * 0.14,
          driftSpeedY: 0.16 + Math.random() * 0.14,
          nodes,
          positions: [],
          x: width * definition.fx,
          y: height * definition.fy,
          attention: 0,
          theme: null,
        };
      });
    }

    function resizeCanvas() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }

    function updateClusters(time) {
      const themes = getThemes();

      clusters.forEach((cluster) => {
        cluster.theme = themes[cluster.id];

        const drift = reduceMotion ? 0 : cluster.drift;
        cluster.x = width * cluster.fx + Math.sin(time * cluster.driftSpeedX + cluster.phaseX) * drift;
        cluster.y = height * cluster.fy + Math.cos(time * cluster.driftSpeedY + cluster.phaseY) * drift;
        cluster.attention = 0;

        cluster.positions = cluster.nodes.map((node) => {
          const pulse = reduceMotion ? 0 : Math.sin(time * node.pulseSpeed + node.pulsePhase);
          const angle = node.angle + (reduceMotion ? 0 : time * node.orbitSpeed * 0.12);
          const radial = node.radial + pulse * 4.2;
          const x = cluster.x + Math.cos(angle) * radial;
          const y = cluster.y + Math.sin(angle) * radial;

          return {
            x,
            y,
            size: node.size + pulse * 0.16,
            pulse,
          };
        });
      });
    }

    function getCluster(id) {
      for (let i = 0; i < clusters.length; i++) {
        if (clusters[i].id === id) return clusters[i];
      }
      return null;
    }

    function drawClusterHalo(cluster) {
      const radius = cluster.radius * (1.42 + cluster.attention * 0.18);
      const gradient = ctx.createRadialGradient(cluster.x, cluster.y, cluster.radius * 0.12, cluster.x, cluster.y, radius);
      const theme = cluster.theme;

      gradient.addColorStop(0, rgba(theme.main, 0.035 * cluster.opacity + cluster.attention * 0.08));
      gradient.addColorStop(0.48, rgba(theme.accent, 0.018 * cluster.opacity + cluster.attention * 0.04));
      gradient.addColorStop(1, rgba(theme.main, 0));

      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(cluster.x, cluster.y, radius, 0, TAU);
      ctx.fill();
    }

    function drawBridge(bridge) {
      const from = getCluster(bridge.from);
      const to = getCluster(bridge.to);
      if (!from || !to) return;

      const emphasis = Math.max(from.attention, to.attention);
      const dx = to.x - from.x;
      const dy = to.y - from.y;
      const controlX = (from.x + to.x) / 2 - dy * bridge.bend;
      const controlY = (from.y + to.y) / 2 + dx * bridge.bend;

      ctx.save();
      ctx.setLineDash(emphasis > 0.08 ? [] : [3, 10]);
      ctx.lineWidth = 0.9 + emphasis * 1.2;
      ctx.strokeStyle = rgba(from.theme.outline, 0.04 + emphasis * 0.12);
      ctx.beginPath();
      ctx.moveTo(from.x, from.y);
      ctx.quadraticCurveTo(controlX, controlY, to.x, to.y);
      ctx.stroke();
      ctx.restore();
    }

    function drawIdleMesh(cluster) {
      const points = cluster.positions;
      if (!points.length) return;

      ctx.save();
      ctx.setLineDash(cluster.attention > 0.14 ? [] : [2, 6]);
      ctx.lineWidth = 0.8 + cluster.attention * 0.45;
      ctx.strokeStyle = rgba(cluster.theme.outline, 0.07 * cluster.opacity + cluster.attention * 0.07);
      ctx.beginPath();

      for (let i = 0; i < points.length; i++) {
        const point = points[i];
        const next = points[(i + 1) % points.length];
        ctx.moveTo(point.x, point.y);
        ctx.lineTo(next.x, next.y);

        if (i % 2 === 0) {
          ctx.moveTo(cluster.x, cluster.y);
          ctx.lineTo(point.x, point.y);
        }
      }

      ctx.stroke();
      ctx.restore();
    }

    function drawNodes(cluster) {
      for (let i = 0; i < cluster.positions.length; i++) {
        const point = cluster.positions[i];
        const proximity = 0;
        const radius = point.size + proximity * 1.35;
        const fillColor = proximity > 0.45 ? cluster.theme.accent : cluster.theme.main;
        const alpha = (0.18 + (point.pulse + 1) * 0.045 + cluster.attention * 0.06 + proximity * 0.42) * cluster.opacity;

        ctx.fillStyle = rgba(fillColor, alpha);
        ctx.beginPath();
        ctx.arc(point.x, point.y, radius, 0, TAU);
        ctx.fill();

        ctx.strokeStyle = rgba(cluster.theme.outline, 0.08 + cluster.attention * 0.08 + proximity * 0.22);
        ctx.lineWidth = 0.75;
        ctx.beginPath();
        ctx.arc(point.x, point.y, radius + 1.5, 0, TAU);
        ctx.stroke();
      }
    }

    function drawVisionMarker(cluster) {
      const size = cluster.markerSize + cluster.attention * 3.2;
      ctx.save();
      ctx.translate(cluster.x, cluster.y);
      ctx.lineWidth = 1.1 + cluster.attention * 0.6;
      ctx.strokeStyle = rgba(cluster.theme.main, 0.26 + cluster.attention * 0.26);
      ctx.fillStyle = rgba(cluster.theme.main, 0.1 + cluster.attention * 0.08);
      ctx.beginPath();
      ctx.moveTo(-size, 0);
      ctx.quadraticCurveTo(0, -size * 0.72, size, 0);
      ctx.quadraticCurveTo(0, size * 0.72, -size, 0);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = rgba(cluster.theme.accent, 0.34 + cluster.attention * 0.3);
      ctx.beginPath();
      ctx.arc(0, 0, size * 0.22, 0, TAU);
      ctx.fill();
      ctx.restore();
    }

    function drawLanguageMarker(cluster) {
      const size = cluster.markerSize + cluster.attention * 3;
      const lines = [size * 1.05, size * 0.76, size * 0.92];
      ctx.save();
      ctx.translate(cluster.x, cluster.y);
      ctx.lineCap = 'round';
      for (let i = 0; i < lines.length; i++) {
        const y = (i - 1) * size * 0.42;
        ctx.strokeStyle = rgba(i === 1 ? cluster.theme.accent : cluster.theme.main, 0.2 + cluster.attention * 0.24);
        ctx.lineWidth = 1.4 + cluster.attention * 0.4;
        ctx.beginPath();
        ctx.moveTo(-lines[i] * 0.5, y);
        ctx.lineTo(lines[i] * 0.5, y);
        ctx.stroke();
      }
      ctx.restore();
    }

    function drawTimeMarker(cluster, time) {
      const size = cluster.markerSize + cluster.attention * 3.1;
      ctx.save();
      ctx.translate(cluster.x, cluster.y);
      ctx.strokeStyle = rgba(cluster.theme.main, 0.24 + cluster.attention * 0.22);
      ctx.lineWidth = 1.05 + cluster.attention * 0.45;
      ctx.beginPath();
      ctx.arc(0, 0, size, 0, TAU);
      ctx.stroke();
      ctx.strokeStyle = rgba(cluster.theme.accent, 0.28 + cluster.attention * 0.26);
      ctx.beginPath();
      ctx.arc(0, 0, size * 0.55, 0, TAU);
      ctx.stroke();
      const handAngle = reduceMotion ? -Math.PI / 4 : time * 1.3;
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(Math.cos(handAngle) * size * 0.65, Math.sin(handAngle) * size * 0.65);
      ctx.stroke();
      ctx.restore();
    }

    function drawSpaceMarker(cluster) {
      const size = cluster.markerSize + cluster.attention * 3.2;
      ctx.save();
      ctx.translate(cluster.x, cluster.y);
      ctx.lineCap = 'round';
      ctx.lineWidth = 1.15 + cluster.attention * 0.45;
      ctx.strokeStyle = rgba(cluster.theme.accent, 0.28 + cluster.attention * 0.22);
      ctx.beginPath();
      ctx.moveTo(0, -size);
      ctx.lineTo(0, size * 0.84);
      ctx.stroke();
      ctx.strokeStyle = rgba(cluster.theme.main, 0.24 + cluster.attention * 0.22);
      ctx.beginPath();
      ctx.moveTo(-size * 0.92, size * 0.48);
      ctx.lineTo(size * 0.96, size * 0.48);
      ctx.stroke();
      ctx.strokeStyle = rgba(cluster.theme.outline, 0.22 + cluster.attention * 0.2);
      ctx.beginPath();
      ctx.moveTo(-size * 0.76, -size * 0.4);
      ctx.lineTo(size * 0.76, size * 0.96);
      ctx.stroke();
      ctx.restore();
    }

    function drawEmbodimentMarker(cluster) {
      const size = cluster.markerSize + cluster.attention * 2.8;
      ctx.save();
      ctx.translate(cluster.x, cluster.y);
      ctx.strokeStyle = rgba(cluster.theme.main, 0.24 + cluster.attention * 0.22);
      ctx.lineWidth = 1.1 + cluster.attention * 0.4;
      ctx.beginPath();
      ctx.moveTo(0, -size);
      ctx.lineTo(-size * 0.86, size * 0.66);
      ctx.lineTo(size * 0.86, size * 0.66);
      ctx.closePath();
      ctx.stroke();
      ctx.fillStyle = rgba(cluster.theme.accent, 0.24 + cluster.attention * 0.24);
      ctx.beginPath();
      ctx.arc(0, -size, 2.2, 0, TAU);
      ctx.arc(-size * 0.86, size * 0.66, 2.2, 0, TAU);
      ctx.arc(size * 0.86, size * 0.66, 2.2, 0, TAU);
      ctx.fill();
      ctx.restore();
    }

    function drawMarker(cluster, time) {
      switch (cluster.id) {
        case 'vision':
          drawVisionMarker(cluster);
          break;
        case 'language':
          drawLanguageMarker(cluster);
          break;
        case 'time':
          drawTimeMarker(cluster, time);
          break;
        case 'space':
          drawSpaceMarker(cluster);
          break;
        case 'embodiment':
          drawEmbodimentMarker(cluster);
          break;
      }
    }

    function render(now) {
      const time = now * 0.00045;
      updateClusters(time);

      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < clusters.length; i++) drawClusterHalo(clusters[i]);
      for (let i = 0; i < BRIDGES.length; i++) drawBridge(BRIDGES[i]);
      for (let i = 0; i < clusters.length; i++) drawIdleMesh(clusters[i]);
      for (let i = 0; i < clusters.length; i++) drawMarker(clusters[i], time);
      for (let i = 0; i < clusters.length; i++) drawNodes(clusters[i]);
    }

    function step(now) {
      render(now);
      animationId = requestAnimationFrame(step);
    }

    function start() {
      if (animationId) return;
      animationId = requestAnimationFrame(step);
    }

    function stop() {
      if (!animationId) return;
      cancelAnimationFrame(animationId);
      animationId = 0;
    }

    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        resizeCanvas();
      }, 160);
    });

    if (typeof reduceMotionQuery.addEventListener === 'function') {
      reduceMotionQuery.addEventListener('change', onReducedMotionChange);
    } else if (typeof reduceMotionQuery.addListener === 'function') {
      reduceMotionQuery.addListener(onReducedMotionChange);
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    document.addEventListener('astro:after-swap', () => {
      resizeCanvas();
      start();
    });

    resizeCanvas();
    createClusters();
    start();
  })();
</script>
