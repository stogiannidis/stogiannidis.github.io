---
const news = [
  { date: 'Jul. 2026', content: 'Attending Greeks in AI in Athens (15-17 July).', highlight: true },
  { date: 'Jun. 2026', content: 'Attending the HERON 1st Robotics School in Athens (29-30 June).', highlight: true },
  {
    date: 'May 2026',
    content: 'PhenoAssistant has been accepted in Nature Communications.',
    url: 'https://www.nature.com/articles/s41467-026-71090-y',
    highlight: true,
  },
  {
    date: 'May 2026',
    content: 'Our paper "Anatomy-Grounded Weakly Supervised Prompt Tuning for Chest X-ray Latent Diffusion Models" has been accepted to MIDL (Medical Imaging with Deep Learning) 2026.',
    url: 'https://arxiv.org/abs/2506.10633',
    highlight: true,
  },
  { date: 'Mar. 2026', content: 'Attended the ELLIS Winter School on Foundation Models in Amsterdam.', highlight: false },
  { date: 'Dec. 2024', content: 'Visiting AUEB (20th) to give a talk about pursuing a PhD abroad.', highlight: true },
  { date: 'Aug. 2024', content: 'Started PhD at The University of Edinburgh.', highlight: false },
  { date: 'Dec. 2023', content: 'MSc thesis available on NLP Group website.', highlight: false },
  { date: 'Nov. 2023', content: 'Poster presentation at EMNLP 2023 (Singapore).', highlight: false },
  { date: 'Oct. 2023', content: 'Thesis under final review.', highlight: false },
  { date: 'Oct. 2023', content: 'LLM caching paper accepted to Findings of EMNLP 2023.', highlight: false },
];
---
<h2>News</h2>

<div class="news-timeline">
  {news.map(item => (
    <div class={`news-item reveal ${item.highlight ? 'highlight' : ''}`}>
      <div class="news-date">{item.date}</div>
      <div class="news-content">
        {item.url ? (
          <a href={item.url} target="_blank" rel="noopener noreferrer">{item.content}</a>
        ) : (
          item.content
        )}
      </div>
    </div>
  ))}
</div>

<style>
  .news-timeline {
    margin: 30px 0;
    position: relative;
  }

  .news-item {
    display: flex;
    margin-bottom: 25px;
    padding: 20px;
    background: var(--card-bg);
    border-radius: 12px;
    box-shadow: var(--card-shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-left: 4px solid var(--primary-color);
  }

  .news-item:hover {
    transform: translateX(8px);
    box-shadow: var(--card-hover-shadow);
  }

  .news-item.highlight {
    border-left-color: #ff6b6b;
    background: var(--bg-secondary);
  }

  .news-date {
    min-width: 100px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-right: 20px;
    align-self: flex-start;
  }

  .news-content {
    flex: 1;
    line-height: 1.6;
    color: var(--text-color);
  }

  .news-content a {
    color: inherit;
    text-decoration-color: var(--primary-color);
    text-underline-offset: 3px;
  }

  .news-content a:hover {
    color: var(--primary-color);
  }

  @media (max-width: 768px) {
    .news-item {
      flex-direction: column;
    }
    .news-date {
      margin-bottom: 10px;
      margin-right: 0;
    }
  }
</style>
